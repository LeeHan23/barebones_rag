# ── LLM ──────────────────────────────────────────────────────────────────────
# Toggle: true = local Ollama, false = OpenAI
USE_OLLAMA=true

# Ollama (local) — pull a model first: `ollama pull llama3`
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (cloud) — only read when USE_OLLAMA=false
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=   # Optional: for OpenAI-compatible APIs (LM Studio, etc.)

# ── Embeddings ────────────────────────────────────────────────────────────────
# bge-m3 is already cached on this machine from bare_NutriChatbot fine-tuning
EMBEDDING_MODEL=BAAI/bge-m3

# Optional: path to LoRA adapter from finetune_embeddings.py
# EMBEDDING_ADAPTER_PATH=~/models/embedding_lora

# ── Storage ───────────────────────────────────────────────────────────────────
CHROMA_PATH=/mnt/ext/barebones_rag/data/chroma
